        </mxCell>
        <mxCell id="FLz81D7HwueDxIbVB6VR-21" value="Анализ текущей архитектуру нужен для сбора и уточнения сведений.&lt;div&gt;Без этого этапа, нельзя составить план действий&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="110" y="-110" width="250" height="80" as="geometry" />
        </mxCell>
        <mxCell id="FLz81D7HwueDxIbVB6VR-24" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="FLz81D7HwueDxIbVB6VR-23" target="FLz81D7HwueDxIbVB6VR-10">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="FLz81D7HwueDxIbVB6VR-23" value="Описание доменов и их границ необходимо, чтобы корректно, ожидаемо и понятно, разбить всю систему" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="400" y="-110" width="220" height="60" as="geometry" />
        </mxCell>
        <mxCell id="FLz81D7HwueDxIbVB6VR-26" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;" edge="1" parent="1" source="FLz81D7HwueDxIbVB6VR-25" target="FLz81D7HwueDxIbVB6VR-17">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="FLz81D7HwueDxIbVB6VR-27" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="FLz81D7HwueDxIbVB6VR-25" target="FLz81D7HwueDxIbVB6VR-18">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="FLz81D7HwueDxIbVB6VR-28" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="FLz81D7HwueDxIbVB6VR-25" target="FLz81D7HwueDxIbVB6VR-20">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="FLz81D7HwueDxIbVB6VR-29" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=1;exitY=0.5;exitDx=0;exitDy=0;entryX=0;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="FLz81D7HwueDxIbVB6VR-25" target="FLz81D7HwueDxIbVB6VR-19">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="FLz81D7HwueDxIbVB6VR-25" value="Команды тут весьма условны, тк мы не знаем какие специалисты есть в организации.&lt;div&gt;&lt;br&gt;&lt;/div&gt;&lt;div&gt;Вообще, для планирования, очень важно знать какие ресурсы есть в наличии&lt;/div&gt;" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="-370" y="20" width="190" height="160" as="geometry" />
        </mxCell>
        <mxCell id="FLz81D7HwueDxIbVB6VR-31" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=1;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="FLz81D7HwueDxIbVB6VR-30" target="FLz81D7HwueDxIbVB6VR-11">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="FLz81D7HwueDxIbVB6VR-30" value="Нужно обновить интеграционную шину, чтобы избежать возможных угроз безопасности, а также, добавить новые возможности интеграции в будущем" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="650" y="-10" width="290" height="60" as="geometry" />
        </mxCell>
        <mxCell id="FLz81D7HwueDxIbVB6VR-33" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0;exitY=0.5;exitDx=0;exitDy=0;entryX=1;entryY=0.5;entryDx=0;entryDy=0;" edge="1" parent="1" source="FLz81D7HwueDxIbVB6VR-32" target="FLz81D7HwueDxIbVB6VR-12">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="FLz81D7HwueDxIbVB6VR-32" value="При таком серьезном изменении в работе компании, стоит потратить время и провести обучение персонала. Это позволит быстрее перестроиться, совершать меньше ошибок, как следствие повысить эффективность бизнеса" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="830" y="325" width="330" height="90" as="geometry" />
        </mxCell>
        <mxCell id="FLz81D7HwueDxIbVB6VR-35" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=0;exitDx=0;exitDy=0;" edge="1" parent="1" source="FLz81D7HwueDxIbVB6VR-34" target="FLz81D7HwueDxIbVB6VR-14">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="FLz81D7HwueDxIbVB6VR-36" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;exitX=0.5;exitY=0;exitDx=0;exitDy=0;" edge="1" parent="1" source="FLz81D7HwueDxIbVB6VR-34" target="FLz81D7HwueDxIbVB6VR-13">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="FLz81D7HwueDxIbVB6VR-34" value="Менять DWH будет слишком дорого, учитывая количество данных и кастомизаций. А вот обновить и оптимизировать - во первых, повысится скрость работы, во вторых будут закрыты какие-то уязвимости. Плюс, это не будет так болезненно для организации" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;" vertex="1" parent="1">
          <mxGeometry x="200" y="660" width="360" height="130" as="geometry" />
        </mxCell>
      </root>
